{
  "name": "formmint",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "A local-first preflight and preparation workbench for Roblox rigid accessory models.",
  "author": "RepoEnjoyer",
  "license": "MIT",
  "scripts": {
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20.19"
  }
}
